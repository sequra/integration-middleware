{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(vendor/bin/phpunit:*)",
      "Bash(composer install:*)",
      "Bash(composer update:*)",
      "Bash(composer dump-autoload:*)",
      "Bash(composer show:*)",
      "Bash(composer validate:*)",
      "Bash(composer outdated:*)",
      "Bash(php -l:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git --version)",
      "Bash(git check-attr:*)",
      "Skill(sq-git:commit)",
      "Skill(sq-git:open-pr)",
      "Skill(sq-git:sync-branch)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ],
    "ask": [
      "Bash(git push:*)"
    ]
  }
}
